ENGLISH_TECH_ENV=production
ENGLISH_TECH_DATABASE_URL=postgresql+psycopg://english_tech:english_tech@postgres:5432/english_tech
ENGLISH_TECH_REQUIRE_POSTGRES_IN_PRODUCTION=true
ENGLISH_TECH_RATE_LIMIT_BACKEND=redis
ENGLISH_TECH_REDIS_URL=redis://redis:6379/0
ENGLISH_TECH_LLM_PROVIDER=ollama
ENGLISH_TECH_LLM_BASE_URL=http://host.docker.internal:11434
ENGLISH_TECH_LLM_MODEL=llama3.2:latest
ENGLISH_TECH_AUTH_ACCESS_TTL_MINUTES=720
ENGLISH_TECH_AUTH_REFRESH_TTL_DAYS=30
ENGLISH_TECH_AUTH_RATE_LIMIT_PER_MINUTE=20
ENGLISH_TECH_AUDIO_RATE_LIMIT_PER_MINUTE=60
ENGLISH_TECH_COACH_WS_RATE_LIMIT_PER_MINUTE=120
ENGLISH_TECH_LESSON_WS_RATE_LIMIT_PER_MINUTE=240
ENGLISH_TECH_LESSON_AUDIO_CHUNK_RATE_LIMIT_PER_MINUTE=900
